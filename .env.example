# MCP Server
# MCP_PORT=3100                          # set to enable HTTP mode (for deployment)
MCP_API_KEY=replace-me-with-a-strong-random-key

# Choiz admin account (used by the server for all backend calls)
CHOIZ_ADMIN_EMAIL=admin@choiz.com
CHOIZ_ADMIN_PASSWORD=replace-me

# Service Base URLs
LOGIN_CORE_BASE_URL=https://login-core-mx-dev.choiz.com.mx/api
CHOIZ_CORE_BASE_URL=https://choiz-core-mx-dev.choiz.com.mx
MY_ACCOUNT_CORE_BASE_URL=https://my-account-core-mx-dev.choiz.com.mx/api

# Service-to-service API Keys
LOGIN_CORE_API_KEY=replace-me
CHOIZ_CORE_API_KEY=replace-me
MY_ACCOUNT_CORE_API_KEY=replace-me
CHECKOUT_API_KEY=replace-me
